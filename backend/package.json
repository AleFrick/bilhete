{
  "name": "bilhete-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "prod": "cross-env NODE_ENV=production node src/server.js",
    "start": "node src/server.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:dev": "cross-env NODE_ENV=development node scripts/migrate.js up",
    "migrate:prod": "cross-env NODE_ENV=production node scripts/migrate.js up",
    "seed": "node scripts/seed.js up",
    "seed:status": "node scripts/seed.js status",
    "seed:dev": "cross-env NODE_ENV=development node scripts/seed.js up",
    "seed:prod": "cross-env NODE_ENV=production node scripts/seed.js up",
    "docker:build": "node scripts/docker.js build",
    "docker:run": "node scripts/docker.js run",
    "docker:run:prod": "node scripts/docker.js run .env.production",
    "docker:run:dev": "node scripts/docker.js run .env.development",
    "docker:deploy": "npm run docker:build && npm run docker:run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7"
  }
}
